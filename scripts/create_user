"""
Create a user with any role (admin, manager, analyst, auditor).
    python3 create_user.py

Standalone — reads password.env directly, no import db needed.
"""
import bcrypt
import getpass
import os
import psycopg2
from dotenv import load_dotenv

load_dotenv("password.env")

DB_CONFIG = {
    "host"     : os.getenv("DB_HOST"),
    "port"     : os.getenv("DB_PORT"),
    "database" : os.getenv("DB_NAME"),
    "user"     : os.getenv("DB_USER"),
    "password" : os.getenv("DB_PASSWORD"),
}

VALID_ROLES = ("admin", "manager", "analyst", "auditor")

username = input("Username: ").strip()
password = getpass.getpass("Password: ")

role = input(f"Role {VALID_ROLES}: ").strip().lower()
while role not in VALID_ROLES:
    print(f"Invalid role. Choose one of: {', '.join(VALID_ROLES)}")
    role = input("Role: ").strip().lower()

password_hash = bcrypt.hashpw(password.encode("utf-8"), bcrypt.gensalt()).decode("utf-8")

conn = psycopg2.connect(**DB_CONFIG)
cursor = conn.cursor()
try:
    cursor.execute(
        "INSERT INTO users (username, password, role) VALUES (%s, %s, %s)",
        (username, password_hash, role)
    )
    conn.commit()
    print(f"\nUser '{username}' created with role '{role}'.")
except Exception as e:
    print(f"\nError: {e}")
finally:
    cursor.close()
    conn.close()
